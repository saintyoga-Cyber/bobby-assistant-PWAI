# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# On Railway, REDIS_URL is injected automatically after adding the Redis add-on.
# For local Docker Compose use: redis://redis:6379/0
REDIS_URL=
SELF_HOSTED=1

# ── Model selection (optional) ────────────────────────────────────────────────
# Default is claude-haiku-4-5. Upgrade to sonnet for better quality.
CHAT_MODEL=claude-haiku-4-5
VERIFIER_MODEL=claude-haiku-4-5

# ── Optional features ─────────────────────────────────────────────────────────
# Mapbox — enables geocoding for weather/location queries (recommended)
MAPBOX_KEY=

# Perplexity — enables the web_search tool
PERPLEXITY_API_KEY=

# IBM Weather API — enables live weather data for the get_weather tool
IBM_KEY=

# ExchangeRate-API — enables the convert_currency tool
EXCHANGE_RATE_API_KEY=

# Google Maps Static — enables map image widgets
GOOGLE_MAPS_STATIC_KEY=
GOOGLE_MAPS_STATIC_SECRET=
GOOGLE_MAPS_STATIC_MAP_ID=

# Honeycomb — observability/tracing (not needed for personal use)
HONEYCOMB_KEY=

# Discord — routes /feedback submissions to a Discord channel
DISCORD_FEEDBACK_URL=

# MCP — exposes /mcp endpoint so claude.ai can access long-term memory
MCP_AUTH_TOKEN=
MCP_MEMORY_USER_ID=
